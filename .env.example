# Public site URL (optional — defaults to https://islacafemiami.com)
NEXT_PUBLIC_SITE_URL=https://islacafemiami.com

# Instagram Graph API — required for the homepage 2×4 feed at build time
# See docs/INSTAGRAM_SETUP.md for how to generate these values.
#
# INSTAGRAM_ACCESS_TOKEN — Business Manager system-user token (never-expiring), NOT a short-lived user token
# INSTAGRAM_USER_ID      — Instagram Business Account ID (numeric) = 17841463309804205 for @islacafemiami
#                          (this is the Instagram account ID, NOT the Facebook Page ID 1113476308525330)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=17841463309804205

# Google Places API (New) — required for live Google reviews at build time
# See docs/GOOGLE_REVIEWS_SETUP.md for Place ID and API key setup.
#
# GOOGLE_PLACES_API_KEY — API key with Places API (New) enabled
# GOOGLE_PLACE_ID       — Isla Café Place ID (confirmed): ChIJd0_oWsvF2YgRqlJkqFquCR8
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=ChIJd0_oWsvF2YgRqlJkqFquCR8
# NEXT_PUBLIC_GOOGLE_PLACE_ID — optional; enables direct Google review link before live API fetch

# Online ordering link (header/footer Order menu)
# NEXT_PUBLIC_ORDER_UBER_EATS_URL=

# Set all secrets in Cloudflare Pages → Settings → Environment variables (Production)
# For local testing, copy this file to .env.local and fill in the values.
